# Ignore everything by default
*

# Allow directory traversal
!*/

# mkdocs build output (lands here due to docs_dir: .. in mkdocs.yml)
site/

# --- Documentation ---
!README.md
!CLAUDE.md
!AGENT.md

# --- Copilot ---
!.github/copilot-instructions.md
!.github/instructions/
!.github/instructions/*

# --- Git hooks ---
!.githooks/
!.githooks/*

# --- Config ---
!*.yml

# --- Go source ---
!*.go
!go.mod
!go.sum
