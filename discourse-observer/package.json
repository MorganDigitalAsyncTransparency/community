{
  "private": true,
  "name": "discourse-observer",
  "description": "Development toolchain for discourse-observer",
  "scripts": {
    "setup": "npm install && git config core.hooksPath .githooks",
    "lint": "npm run lint:md && npm run lint:go",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules",
    "lint:go": "sh scripts/lint-go.sh",
    "test": "sh scripts/test-go.sh"
  },
  "devDependencies": {
    "markdownlint-cli": "^0.48.0"
  }
}
