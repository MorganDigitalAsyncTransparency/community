{
  "private": true,
  "name": "discourse-observer",
  "description": "Development toolchain for discourse-observer",
  "scripts": {
    "setup": "npm install && cd frontend && npm install && cd .. && git config core.hooksPath .githooks",
    "lint": "npm run lint:md && npm run lint:go && npm run lint:frontend",
    "lint:md": "markdownlint \"**/*.md\" --ignore \"**/node_modules/**\"",
    "lint:go": "sh scripts/lint-go.sh",
    "lint:frontend": "sh scripts/lint-frontend.sh",
    "test": "sh scripts/test-go.sh && sh scripts/test-frontend.sh"
  },
  "devDependencies": {
    "markdownlint-cli": "^0.48.0"
  }
}
