# Discourse API connection
#
# Default: mock server running as a Docker service (no real Discourse instance needed).
# For local non-Docker development, use http://localhost:9920 instead.
# Replace with your forum URL and credentials for production use.
DISCOURSE_BASE_URL=http://mockserver:9920
DISCOURSE_API_TOKEN=
DISCOURSE_API_USER=

# Mock server page size (optional — default 30, docker-compose sets 5 for visible pagination)
# MOCK_PAGE_SIZE=5

# Sync scheduling (all optional — defaults shown)
#
# SYNC_INITIAL_DELAY_SECONDS=20
# SYNC_DELTA_DELAY_SECONDS=2
# SYNC_INTERVAL=900
# SYNC_LOW_ACTIVITY_THRESHOLD=3
# SYNC_MAX_RETRIES=3
# SYNC_JITTER_SECONDS=60
