#!/bin/sh
set -e

cd "$(git rev-parse --show-toplevel)/discourse-observer"

echo "Running pre-commit checks..."

# Protect secrets
if git diff --cached --name-only | grep -qE '\.env$|\.env\.local$|\.env\.production$'; then
  echo "ERROR: Attempting to commit .env file with potential secrets."
  echo "If this is intentional, use --no-verify (not recommended)."
  exit 1
fi

echo "Linting Markdown..."
npx markdownlint "**/*.md" --ignore node_modules --ignore frontend

echo "Linting Go..."
sh scripts/lint-go.sh

echo "Running Go tests..."
sh scripts/test-go.sh

echo "Checking frontend types..."
sh scripts/check-frontend.sh

echo "Linting frontend..."
sh scripts/lint-frontend.sh

echo "Running frontend tests..."
sh scripts/test-frontend.sh

echo "All pre-commit checks passed."
