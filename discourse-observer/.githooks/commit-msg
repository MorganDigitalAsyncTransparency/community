#!/bin/sh

msg_file="$1"
first_line=$(head -n 1 "$msg_file")

# Allow merge commits
if echo "$first_line" | grep -qE '^Merge '; then
  exit 0
fi

# First line must not be empty
if [ -z "$first_line" ]; then
  echo "ERROR: Commit message must not be empty."
  exit 1
fi

# First line max 72 characters
length=$(printf '%s' "$first_line" | tr -d '\n' | wc -m)
if [ "$length" -gt 72 ]; then
  echo "ERROR: First line is $length characters (max 72)."
  echo "  $first_line"
  exit 1
fi

# Must start with uppercase letter
if ! echo "$first_line" | grep -qE '^[A-Z]'; then
  echo "ERROR: Commit message must start with an uppercase letter."
  echo "  $first_line"
  exit 1
fi

# Must not end with a period
if echo "$first_line" | grep -qE '\.$'; then
  echo "ERROR: Commit message must not end with a period."
  echo "  $first_line"
  exit 1
fi
